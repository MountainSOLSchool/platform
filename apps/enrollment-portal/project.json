{
    "name": "enrollment-portal",
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "projectType": "application",
    "sourceRoot": "apps/enrollment-portal/src",
    "prefix": "sol",
    "tags": [],
    "targets": {
        "build": {
            "executor": "@angular-devkit/build-angular:browser",
            "outputs": ["{options.outputPath}"],
            "options": {
                "outputPath": "dist/apps/enrollment-portal",
                "index": "apps/enrollment-portal/src/index.html",
                "main": "apps/enrollment-portal/src/main.ts",
                "polyfills": "apps/enrollment-portal/src/polyfills.ts",
                "tsConfig": "apps/enrollment-portal/tsconfig.app.json",
                "assets": [
                    "apps/enrollment-portal/src/favicon.ico",
                    "apps/enrollment-portal/src/assets",
                    {
                        "glob": "**/*",
                        "input": "libs/angular/header/src/lib/assets/",
                        "output": "./assets/header/"
                    }
                ],
                "styles": [
                    "node_modules/@angular/cdk/overlay-prebuilt.css",
                    "apps/enrollment-portal/src/design-tokens.scss",
                    "apps/enrollment-portal/src/custom-theme.scss",
                    "apps/enrollment-portal/src/styles.css",
                    "node_modules/primeflex/primeflex.css"
                ],
                "scripts": []
            },
            "configurations": {
                "production": {
                    "budgets": [
                        {
                            "type": "initial",
                            "maximumWarning": "1mb",
                            "maximumError": "2mb"
                        },
                        {
                            "type": "anyComponentStyle",
                            "maximumWarning": "2kb",
                            "maximumError": "4kb"
                        }
                    ],
                    "fileReplacements": [
                        {
                            "replace": "apps/enrollment-portal/src/environments/environment.ts",
                            "with": "apps/enrollment-portal/src/environments/environment.prod.ts"
                        }
                    ],
                    "outputHashing": "all"
                },
                "dev": {
                    "budgets": [
                        {
                            "type": "initial",
                            "maximumWarning": "1mb",
                            "maximumError": "2mb"
                        },
                        {
                            "type": "anyComponentStyle",
                            "maximumWarning": "2kb",
                            "maximumError": "4kb"
                        }
                    ],
                    "fileReplacements": [
                        {
                            "replace": "apps/enrollment-portal/src/environments/environment.ts",
                            "with": "apps/enrollment-portal/src/environments/environment.dev.ts"
                        },
                        {
                            "replace": "libs/ts/firebase/firebase-config/src/lib/sol-firebase-config.ts",
                            "with": "libs/ts/firebase/firebase-config/src/lib/sol-firebase-config.dev.ts"
                        }
                    ],
                    "outputHashing": "all"
                },
                "development": {
                    "buildOptimizer": false,
                    "optimization": false,
                    "vendorChunk": true,
                    "extractLicenses": false,
                    "sourceMap": true,
                    "namedChunks": true,
                    "baseHref": "/"
                },
                "emulator": {
                    "buildOptimizer": false,
                    "optimization": false,
                    "vendorChunk": true,
                    "extractLicenses": false,
                    "sourceMap": true,
                    "namedChunks": true,
                    "baseHref": "/",
                    "fileReplacements": [
                        {
                            "replace": "apps/enrollment-portal/src/environments/environment.ts",
                            "with": "apps/enrollment-portal/src/environments/environment.emulator.ts"
                        }
                    ]
                }
            },
            "defaultConfiguration": "production"
        },
        "serve": {
            "executor": "@angular-devkit/build-angular:dev-server",
            "configurations": {
                "production": {
                    "buildTarget": "enrollment-portal:build:production"
                },
                "dev": {
                    "buildTarget": "enrollment-portal:build:dev"
                },
                "development": {
                    "buildTarget": "enrollment-portal:build:development",
                    "proxyConfig": "apps/enrollment-portal/proxy.conf.json"
                },
                "emulator": {
                    "buildTarget": "enrollment-portal:build:emulator",
                    "proxyConfig": "apps/enrollment-portal/proxy.conf.json",
                    "liveReload": false,
                    "hmr": false
                }
            },
            "defaultConfiguration": "development",
            "continuous": true
        },
        "extract-i18n": {
            "executor": "@angular-devkit/build-angular:extract-i18n",
            "options": {
                "buildTarget": "enrollment-portal:build"
            }
        },
        "lint": {
            "executor": "@nx/eslint:lint",
            "outputs": ["{options.outputFile}"]
        },
        "test": {
            "executor": "@nx/jest:jest",
            "outputs": ["{workspaceRoot}/coverage/apps/enrollment-portal"],
            "options": {
                "jestConfig": "apps/enrollment-portal/jest.config.ts",
                "tsConfig": "apps/enrollment-portal/tsconfig.spec.json"
            }
        },
        "storybook": {
            "executor": "@storybook/angular:start-storybook",
            "options": {
                "configDir": "apps/enrollment-portal/.storybook",
                "browserTarget": "enrollment-portal:build",
                "compodoc": false,
                "tsConfig": "apps/enrollment-portal/.storybook/tsconfig.storybook.json",
                "port": 4400
            }
        },
        "build-storybook": {
            "executor": "@storybook/angular:build-storybook",
            "outputs": ["{options.outputDir}"],
            "options": {
                "configDir": "apps/enrollment-portal/.storybook",
                "browserTarget": "enrollment-portal:build",
                "compodoc": false,
                "tsConfig": "apps/enrollment-portal/.storybook/tsconfig.storybook.json",
                "outputDir": "dist/storybook/enrollment-portal"
            }
        }
    }
}
